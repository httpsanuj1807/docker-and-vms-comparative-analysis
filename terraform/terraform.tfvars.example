# =============================================================================
# Terraform Variables Example
# Research: Comparative Analysis of Docker Containers vs Virtual Machines
# =============================================================================
# Copy this file to terraform.tfvars and customize as needed
# =============================================================================

# AWS Region - choose region closest to your location for lower latency
aws_region = "us-east-1"

# Project name for resource naming
project_name = "docker-vm-research"

# Network Configuration
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# EC2 Instance Types
# ------------------------------------------------------------------------------
# These are selected to match research paper specifications:
# - 16 cores, 64GB RAM, NVMe storage, 10Gbps+ networking
# ------------------------------------------------------------------------------

# Docker Host: Compute optimized for containerized workloads
# c6i.4xlarge: 16 vCPUs, 32GB RAM, up to 12.5 Gbps network
docker_host_instance_type = "c6i.4xlarge"

# VM Host: Bare metal for KVM/nested virtualization support
# c6i.metal: 128 vCPUs, 256GB RAM, full hardware access for KVM
# NOTE: This is expensive - consider c6i.8xlarge for testing (won't have KVM)
vm_host_instance_type = "c6i.metal"

# Load Generator: Sufficient for running JMeter with 500 concurrent users
# c6i.2xlarge: 8 vCPUs, 16GB RAM
load_generator_instance_type = "c6i.2xlarge"

# Storage Configuration
root_volume_size = 100  # GB - OS and base software
data_volume_size = 200  # GB - Docker images, VM images, results

# SSH Access - IMPORTANT: Restrict this to your IP in production
# Example: ["203.0.113.0/24"] for your office CIDR
allowed_ssh_cidr = ["0.0.0.0/0"]

# SSH Key name
key_name = "docker-vm-research-key"

# Application Configuration
nodejs_version = "18"
app_port       = 3000

# JMeter Version
jmeter_version = "5.6.3"

# Enable detailed CloudWatch monitoring (additional cost)
enable_enhanced_monitoring = true

# =============================================================================
# Cost Considerations:
# =============================================================================
# c6i.4xlarge:  ~$0.68/hour
# c6i.metal:    ~$5.44/hour (required for KVM)
# c6i.2xlarge:  ~$0.34/hour
# EBS gp3:      ~$0.08/GB/month
#
# Estimated hourly cost for all instances: ~$6.50/hour
# Consider using spot instances for non-critical testing
# =============================================================================
